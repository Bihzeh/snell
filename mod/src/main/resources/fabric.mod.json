{
  "schemaVersion": 1,
  "id": "snell",
  "version": "${version}",
  "name": "Snell",
  "description": "Server-legal performance + quality-of-life client: HUD, mod menu, cosmetics.",
  "authors": ["Snell"],
  "contact": {
    "homepage": "https://github.com/Bihzeh/snell",
    "sources": "https://github.com/Bihzeh/snell",
    "issues": "https://github.com/Bihzeh/snell/issues"
  },
  "license": "LicenseRef-Snell-Proprietary",
  "environment": "client",
  "entrypoints": {
    "client": [
      { "adapter": "kotlin", "value": "gg.snell.mod.SnellMod" }
    ]
  },
  "mixins": [
    { "config": "snell.mixins.json", "environment": "client" }
  ],
  "depends": {
    "fabricloader": ">=${loader}",
    "minecraft": "~${minecraft}",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}
